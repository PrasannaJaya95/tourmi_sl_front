generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String?
  name      String
  role      String   @default("CUSTOMER") // ADMIN, STAFF, DRIVER, CUSTOMER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // bookings  Booking[] // Moved to Client model
  driverDetails DriverDetails?

  permissionGroupId String?          @db.ObjectId
  permissionGroup   PermissionGroup? @relation(fields: [permissionGroupId], references: [id])
  
  vendorVehicles    Vehicle[]      @relation("VendorVehicles")
  vendorDetails     VendorDetails?
  vendorBills       VendorBill[]   @relation("VendorBills")
}

model VendorDetails {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @unique @db.ObjectId
  user           User     @relation(fields: [userId], references: [id])
  
  phone          String?
  address        String?
  nic            String?
  
  nicFrontUrl    String?
  nicBackUrl     String?
  
  utilityBillUrl String?
  attachment1Url String?
  attachment2Url String?
  
  vendorCode     String?  @unique // VEN/00001
  photoUrl       String?

  vendorType     String? // "VEHICLE_OWNER", "SERVICE_VENDOR"

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PermissionGroup {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  permissions String   // JSON string of permission codes
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Client {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  code                String   @unique // CUS/00001
  type                String   // LOCAL, FOREIGN, CORPORATE
  status              String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, CONFIRMED
  
  // Common Fields
  email               String?
  phone               String?
  mobile              String?
  address             String?
  description         String?
  
  // Local/Foreign Fields
  name                String?
  nicOrPassport       String?  // Local
  passportNo          String?  // Foreign
  drivingLicenseNo    String?
  
  // Corporate Fields
  companyName         String?
  brNumber            String?
  contactPersonName   String?
  contactPersonMobile String?

  // Relations (Local)
  closeRelationName   String?
  closeRelationMobile String?
  
  // Documents (URLs)
  doc1Url                    String?
  doc2Url                    String?
  utilityBillUrl             String?
  drivingLicenseFrontUrl     String?
  drivingLicenseBackUrl      String?
  support1Url                String?
  support2Url                String?
  
  // Foreign Documents (URLs)
  intlDrivingLicenseFrontUrl String?
  intlDrivingLicenseBackUrl  String?
  aaPermitUrl                String?
  
  // New Fields for System Sync
  userId              String?  @db.ObjectId
  loyaltyPoints       Float    @default(0)
  loyaltyEnabled      Boolean  @default(true)
  loyaltyEarnRate     Float?
  loyaltyRedeemRate   Float?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  bookings            Booking[]
  contracts           Contract[]
  invoices            Invoice[]
  agreements          Agreement[]
  ledgerEntries       LedgerEntry[]
  quotations          Quotation[]

  @@index([status])
}

model DriverDetails {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  userId         String @unique @db.ObjectId
  user           User   @relation(fields: [userId], references: [id])
  licenseNumber  String
  licenseExpiryDate DateTime?
  phoneNumber    String?
  address        String?
  nic            String? 

  licenseFrontUrl String?
  licenseBackUrl  String?
  nicFrontUrl     String?
  nicBackUrl      String?
  driverImageUrl  String?

  status         String @default("ACTIVE") // ACTIVE, ON_LEAVE
  createdAt      DateTime @default(now())
}

model VehicleBrand {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  name      String         @unique
  models    VehicleModel[]
}

model VehicleModel {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  brandId   String   @db.ObjectId
  brand     VehicleBrand @relation(fields: [brandId], references: [id])
  vehicles  Vehicle[]
  
  @@unique([name, brandId])
}

model Vehicle {
  id                    String        @id @default(auto()) @map("_id") @db.ObjectId
  // Relation to Model (which links to Brand)
  modelId               String?       @db.ObjectId
  vehicleModel          VehicleModel? @relation(fields: [modelId], references: [id])
  
  year                  Int
  licensePlate          String        
  vin                   String?       
  color                 String
  fuelType              String        // Petrol, Diesel, Electric, Hybrid
  transmission          String        // Automatic, Manual
  
  // New Fields
  lastOdometer          Int?
  licenseFrontUrl       String?
  licenseBackUrl        String?
  licenseRenewalDate    DateTime?
  insuranceFrontUrl     String?
  insuranceBackUrl      String?
  additionalImages      String? // JSON string for extra 4 images
  insuranceRenewalDate  DateTime?
  financeInstallmentDate DateTime?

  // New Fields
  ownership     String        @default("COMPANY") // COMPANY, THIRD_PARTY
  rentalType    String?       @default("SHORT_TERM") // SHORT_TERM, LONG_TERM
  vendorId      String?       @db.ObjectId
  vendor        User?         @relation("VendorVehicles", fields: [vendorId], references: [id])
  
  fleetCategoryId String?      @db.ObjectId
  fleetCategory   FleetCategory? @relation(fields: [fleetCategoryId], references: [id])

  status        String        @default("AVAILABLE") // AVAILABLE, RENTED, MAINTENANCE, RESERVED
  imageUrl      String?
  features      String?       // "GPS,Bluetooth,Sunroof"
  
  dailyRentalRate Float?    @default(0)
  foreignDailyRentalRate Float? @default(0)
  bookingFee      Float?    @default(0)
  dailyAllocatedKm Int?       @default(100)
  extraKmCharge   Float?    @default(0)
  
  contractStartDate     DateTime?
  contractEndDate       DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  bookings      Booking[]
  contracts     Contract[]
  invoices      Invoice[]
  agreements    Agreement[]
  ledgerEntries LedgerEntry[]
  quotations    Quotation[]
  maintenances  Maintenance[]
  inspections   Inspection[]
  exchangesAsOld VehicleExchange[] @relation("OldVehicle")
  exchangesAsNew VehicleExchange[] @relation("NewVehicle")
  odometers     Odometer[]
  expenses      VehicleExpense[]
  paymentSchedules VehiclePaymentSchedule[]
  vendorBills   VendorBill[]
}

model FleetCategory {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String    @unique
  sortOrder Int       @default(0)
  vehicles  Vehicle[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Odometer {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId String   @db.ObjectId
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  reading   Int
  source    String? // "MANUAL", "VEHICLE_UPDATE", "CONTRACT_END"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  clientId      String        @db.ObjectId
  client        Client        @relation(fields: [clientId], references: [id])
  vehicleId     String        @db.ObjectId
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  startDate     DateTime
  endDate       DateTime
  totalAmount   Float
  status        String        @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  payments      Payment[]
  rentalAgreement RentalAgreement?

  @@index([status])
  @@index([clientId])
  @@index([vehicleId])
}

model Maintenance {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId   String   @db.ObjectId
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  description String
  cost        Float?   // Optional until status is DONE
  startDate   DateTime
  endDate     DateTime? // Optional until status is DONE
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, DONE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paidByCompany Boolean @default(false)
  vendorBillId  String? @db.ObjectId
  vendorBill    VendorBill? @relation(fields: [vendorBillId], references: [id])
  isRealized    Boolean @default(false)
}

model VehicleExpense {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId   String   @db.ObjectId
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  description String
  amount      Float
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paidByCompany Boolean @default(false)
  vendorBillId  String? @db.ObjectId
  vendorBill    VendorBill? @relation(fields: [vendorBillId], references: [id])
  isRealized    Boolean @default(false)
}

model Inspection {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId   String   @db.ObjectId
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date        DateTime
  notes       String?
  passed      Boolean
  reportUrl   String?
}

model Payment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  bookingId   String   @db.ObjectId
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount      Float
  method      String   // CREDIT_CARD, CASH, TRANSFER
  status      String   // PAID, PENDING, FAILED
  date        DateTime @default(now())
}

model RentalAgreement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  bookingId   String   @unique @db.ObjectId
  booking     Booking  @relation(fields: [bookingId], references: [id])
  termsAndConditions String
  signedAt    DateTime?
}

model Quotation {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  quotationNo String @unique @map("quotation_no")
  issueDate   DateTime @default(now()) @map("issue_date")
  validUntil  DateTime @map("valid_until")

  customerMode String @map("customer_mode") // EXISTING, NEW
  customerId   String? @db.ObjectId @map("customer_id")
  customer     Client? @relation(fields: [customerId], references: [id])
  customerName String @map("customer_name")
  customerEmail String? @map("customer_email")
  customerType String @map("customer_type") // LOCAL, FOREIGN, CORPORATE

  vehicleId String @db.ObjectId @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  pickupDate DateTime @map("pickup_date")
  dropoffDate DateTime @map("dropoff_date")
  rentalDays Int @map("rental_days")
  dailyRate  Float @map("daily_rate")

  baseAmount  Float @map("base_amount")
  extraChargesJson String @map("extra_charges_json") // JSON string [{description, amount}]
  extraAmount Float @map("extra_amount")
  totalAmount Float @map("total_amount")

  /// Refundable security deposit. Included in totalAmount so the customer sees the up-front amount,
  /// but tracked separately so it can be excluded from revenue / P&L downstream (quotations themselves do not hit P&L).
  securityDeposit Float @default(0) @map("security_deposit")

  /// Opaque public share key for short customer links (e.g. /api/q/abc12xY9zQ8m)
  shareToken String? @unique @map("share_token")

  createdByUserId String? @db.ObjectId @map("created_by_user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model SystemSetting {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  key   String @unique
  value String
}

model EmailSettings {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  smtpHost   String @map("smtp_host")
  smtpPort   Int @map("smtp_port")
  username   String
  password   String
  encryption String @map("encryption") // TLS/SSL/NONE

  fromEmail String @map("from_email")
  fromName  String @map("from_name")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_settings")
}

model EmailLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  toEmail      String @map("to_email")
  subject      String
  status       String // success/failed
  errorMessage String? @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("email_logs")
}

model EmailTemplate {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  templateKey     String @unique @map("template_key")
  subjectTemplate String @map("subject_template")
  htmlTemplate    String @map("html_template")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

model District {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model City {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  districtId String   @db.ObjectId
  district   District @relation(fields: [districtId], references: [id])
  contracts  Contract[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@unique([name, districtId])
}

model Contract {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  contractNo         String?  @unique
  
  // Relations
  customerId         String   @db.ObjectId
  customer           Client   @relation(fields: [customerId], references: [id])
  vehicleId          String   @db.ObjectId
  vehicle            Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  invoices           Invoice[]
  agreements         Agreement[]
  ledgerEntries      LedgerEntry[]
  
  // Status
  status             String   @default("UPCOMING") // UPCOMING, IN_PROGRESS, RETURN, COMPLETED, CANCELLED
  
  // Dates & Time
  pickupDate         DateTime
  pickupTime         String
  dropoffDate        DateTime
  dropoffTime        String 
  actualReturnDate   DateTime?
  actualReturnTime   String?

  // Financials
  appliedDailyRate   Float?
  securityDeposit    Float
  advancePaymentAmount Float? @default(0)
  advancePaymentDate DateTime?
  deliveryCharge     Float? @default(0)
  dailyKmLimit       Int      @default(100)
  allocatedKm        Int      @default(100)
  extraMileageCharge Float  @default(0)
  extraKmCost        Float? @default(0)
  securityDepositReturned Float? @default(0)

  // Additional charges on return (consumed from security deposit)
  damageCharge       Float?   @default(0)
  otherChargeAmount  Float?   @default(0)
  otherChargeDescription String?
  
  // Delivery
  isDelivery         Boolean  @default(false)
  cityId             String?  @db.ObjectId
  city               City?    @relation(fields: [cityId], references: [id])
  isCollection       Boolean  @default(false)
  collectionCharge   Float? @default(0)
  
  // Vehicle State
  fuelLevel          String // FULL, HALF, LOW
  startOdometer      Int
  endOdometer        Int?
  
  // Checklist (Booleans)
  license            Boolean  @default(false)
  insurance          Boolean  @default(false)
  carpets            Boolean  @default(false)
  spareWheel         Boolean  @default(false)
  jack               Boolean  @default(false)
  jackHandle         Boolean  @default(false)
  airPump            Boolean  @default(false)
  audioSetup         Boolean  @default(false)
  toolCover          Boolean  @default(false)
  mudCovers          Boolean  @default(false)

  // Return Checklist (Booleans)
  returnLicense      Boolean  @default(false)
  returnInsurance    Boolean  @default(false)
  returnCarpets      Boolean  @default(false)
  returnSpareWheel   Boolean  @default(false)
  returnJack         Boolean  @default(false)
  returnJackHandle   Boolean  @default(false)
  returnAirPump      Boolean  @default(false)
  returnAudioSetup   Boolean  @default(false)
  returnToolCover    Boolean  @default(false)
  returnMudCovers    Boolean  @default(false)

  // Checklist Strings/Other
  batteryCode        String?
  remark             String?

  // Tyres
  frontTyres         String // 100%, 80%, 60%, 40%
  rearTyres          String
  returnFrontTyres   String?
  returnRearTyres    String?

  // Images
  inspectionImages   String? // JSON string for 5 images
  returnInspectionImages String? // JSON string for 5 images generated at return
  
  // Return Strings
  returnBatteryCode  String?
  returnRemark       String?

  // false = hide UPFRONT from GET /invoices/contract/:id until "Create Upfront Invoice" (omit on legacy docs = still show).
  upfrontReleased    Boolean  @default(false)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  vehicleExchanges   VehicleExchange[]
  advanceReceipts    AdvanceReceipt[]

  @@index([status])
  @@index([customerId])
  @@index([vehicleId])
}

model AdvanceReceipt {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  receiptNo   String   @unique
  sequence    Int      // Per-month counter (matches receipt segment); receiptNo is globally unique

  contractId  String   @db.ObjectId
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  amount      Float
  paymentDate DateTime?

  // Posted to upfront invoice + ledger when advance receipt is finalized.
  ledgerPostedAt DateTime?
  // Set when reversal credit note (RAR) reverses the linked payment and P&L.
  reversedAt     DateTime?

  // Was previously a one-to-one (`linkedPayment InvoicePayment?`), but
  // Prisma's MongoDB connector requires the FK side (`InvoicePayment.advanceReceiptId`)
  // to be `@unique` for one-to-one — and `@unique` on an optional field maps
  // to a *regular* MongoDB unique index that treats `null`/missing as a single
  // value, breaking every cash payment after the first one. We model this as
  // one-to-many on the schema so Prisma is happy without `@unique`, and
  // enforce the real "at most one payment per posted advance receipt"
  // invariant via a *partial* unique index created by
  // `back/prisma/ensure-invoice-payment-indexes.js` and the application code
  // in `issueAdvanceReceipt` (which only ever creates one linked payment).
  linkedPayments InvoicePayment[]
  advanceReversal AdvanceReversalCredit?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contractId])
}

model Invoice {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId

  // Sequencing / Identity
  invoiceNo  String   @unique
  sequence   Int      @unique

  // Relations
  contractId String   @db.ObjectId
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  customerId String   @db.ObjectId
  customer   Client   @relation(fields: [customerId], references: [id])
  vehicleId  String   @db.ObjectId
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  // Type + amounts
  type       String   // UPFRONT, FINAL, etc.
  currency   String   @default("LKR")
  subtotal   Float    @default(0)
  total      Float    @default(0)
  status     String   @default("ISSUED") // ISSUED, PARTIALLY_PAID, PAID, VOID
  paidAt     DateTime?
  paidMethod String?  // CASH, TRANSFER, CARD, etc.

  // Line items snapshot
  lines      Json
  ledgerEntries LedgerEntry[]
  creditNotes   CreditNote[]
  payments      InvoicePayment[]
  advanceReversalCredits AdvanceReversalCredit[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([contractId, type])
  @@index([status])
  @@index([customerId])
}

// Reversal credit note for a posted advance receipt (RAR/MM/YYYY/#####).
model AdvanceReversalCredit {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  rarNo            String   @unique
  sequence         Int      // Per-month segment counter (same month can share values across years in display only via rarNo path)

  advanceReceiptId String   @unique @db.ObjectId
  advanceReceipt   AdvanceReceipt @relation(fields: [advanceReceiptId], references: [id], onDelete: Cascade)

  invoiceId        String   @db.ObjectId
  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount           Float
  reason           String?

  createdAt        DateTime @default(now())
}

model Agreement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  agreementNo String   @unique
  sequence    Int      @unique

  contractId  String   @db.ObjectId
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  customerId  String   @db.ObjectId
  customer    Client   @relation(fields: [customerId], references: [id])
  vehicleId   String   @db.ObjectId
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  status      String   @default("GENERATED") // GENERATED, VOID
  data        Json

  // Short opaque token used by /api/a/:shareToken to render the public preview.
  // Not declared as `@unique` because MongoDB regular unique indexes treat
  // missing/`null` values as collisions; instead, a partial unique index is
  // maintained by `back/prisma/ensure-agreement-share-token-index.js`.
  shareToken  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([contractId])
  @@index([shareToken])
}

model LedgerEntry {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  type       String   // INCOME, LIABILITY
  amount     Float
  currency   String   @default("LKR")
  description String?

  invoiceId  String   @db.ObjectId
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  contractId String   @db.ObjectId
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  customerId String   @db.ObjectId
  customer   Client   @relation(fields: [customerId], references: [id])
  vehicleId  String   @db.ObjectId
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@index([vehicleId, createdAt])
  @@index([type, createdAt])
}

model CreditNote {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  creditNoteNo String  @unique
  sequence    Int      @unique

  invoiceId   String   @db.ObjectId
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  reason      String?
  createdAt   DateTime @default(now())
}

model InvoicePayment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  invoiceId String   @db.ObjectId
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Float
  paidAt    DateTime @default(now())
  method    String?

  // Links this payment row to the advance receipt that created it.
  //
  // We INTENTIONALLY do NOT use `@unique` here. Prisma maps `@unique` on an
  // optional field to a regular MongoDB unique index, which treats `null` /
  // missing-field as a single value — that means at most one cash payment in
  // the whole collection can have the field absent, and the second cash
  // payment fails with `InvoicePayment_advanceReceiptId_key`.
  //
  // The "one payment per posted advance receipt" invariant is enforced by:
  //   1. application code in `issueAdvanceReceipt` (one receipt per contract)
  //   2. a partial unique index on `{ advanceReceiptId: 1 }` filtered to
  //      `advanceReceiptId != null`, which must be created on the database
  //      via `back/prisma/ensure-invoice-payment-indexes.js` (one-time per env)
  //      because the Prisma MongoDB connector doesn't model partial indexes.
  advanceReceiptId String?        @db.ObjectId
  advanceReceipt   AdvanceReceipt? @relation(fields: [advanceReceiptId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([advanceReceiptId])
}

model VehiclePaymentSchedule {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  vehicleId String   @db.ObjectId
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime
  monthlyAmount Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorBill {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  billNumber      String?  @unique // Format: Vendor-Bill/00001
  vendorId        String   @db.ObjectId
  vendor          User     @relation("VendorBills", fields: [vendorId], references: [id])
  vehicleId       String   @db.ObjectId
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  month           Int
  year            Int
  billDate        DateTime? // Tracks the period month/year
  monthlyPayment  Float
  repairDeductions Float
  expenseDeductions Float
  totalAmount     Float    // Resulting payment to vendor
  carriedOverBalance Float @default(0)
  description     String?  // Deduction reasons
  status          String   @default("PENDING") // PENDING, PAID
  billingType     String?  @default("LONG_TERM") // LONG_TERM, SHORT_TERM
  billingFrom     DateTime?
  billingTo       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           VendorBillItem[]
  maintenances    Maintenance[]
  expenses        VehicleExpense[]
}

model VendorBillItem {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  vendorBillId String     @db.ObjectId
  vendorBill   VendorBill @relation(fields: [vendorBillId], references: [id], onDelete: Cascade)
  description  String
  amount       Float
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model VehicleExchange {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  
  contractId String   @db.ObjectId
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  oldVehicleId String  @db.ObjectId
  oldVehicle   Vehicle @relation("OldVehicle", fields: [oldVehicleId], references: [id], onDelete: Cascade)
  
  newVehicleId String? @db.ObjectId
  newVehicle   Vehicle? @relation("NewVehicle", fields: [newVehicleId], references: [id], onDelete: Cascade)
  
  exchangeDate DateTime @default(now())
  
  // Breakdown/Return details of Old Vehicle
  oldVehicleReturnDate     DateTime
  oldVehicleReturnOdometer Int
  
  // Handover details of New Vehicle
  newVehicleStartDate     DateTime?
  newVehicleStartOdometer Int?
  newVehicleDailyRate     Float? // Snapshot of rate if category differs

  // Checklist for Old Vehicle Return (Mirrors Return Checklist in Contract)
  returnLicense      Boolean  @default(false)
  returnInsurance    Boolean  @default(false)
  returnCarpets      Boolean  @default(false)
  returnSpareWheel   Boolean  @default(false)
  returnJack         Boolean  @default(false)
  returnJackHandle   Boolean  @default(false)
  returnAirPump      Boolean  @default(false)
  returnAudioSetup   Boolean  @default(false)
  returnToolCover    Boolean  @default(false)
  returnMudCovers    Boolean  @default(false)
  returnRemark       String?
  returnBatteryCode  String?
  returnFrontTyres   String?
  returnRearTyres    String?
  returnInspectionImages String?

  // Checklist for New Vehicle Handover (Mirrors Start Checklist in Contract)
  license            Boolean  @default(false)
  insurance          Boolean  @default(false)
  carpets            Boolean  @default(false)
  spareWheel         Boolean  @default(false)
  jack               Boolean  @default(false)
  jackHandle         Boolean  @default(false)
  airPump            Boolean  @default(false)
  audioSetup         Boolean  @default(false)
  toolCover          Boolean  @default(false)
  mudCovers          Boolean  @default(false)
  remark             String?
  batteryCode        String?
  frontTyres         String?
  rearTyres          String?
  fuelLevel          String?  // FULL, HALF, LOW
  inspectionImages   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
